# Salin file ini ke .env sebelum menjalankan docker compose (nilai di bawah cocok untuk pengembangan lokal).
# Windows (PowerShell): Copy-Item .env.example .env
# Linux/macOS: cp .env.example .env
#
# File ini juga dibaca oleh pipeline ingestion (ingestion/main_ingest.py) melalui python-dotenv.
# Pastikan .env sudah ada sebelum menjalankan: python -m ingestion.main_ingest

POSTGRES_DB=minilabdb
POSTGRES_USER=minilab
POSTGRES_PASSWORD=minilab123
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=datalake

# Tahap 2 — Analisis (opsional)
JUPYTER_PORT=8888

# Tahap 3 — Spark Standalone Cluster (opsional)
# Ubah SPARK_MASTER ke spark://spark-master:7077 saat menggunakan profile cluster
SPARK_MASTER=local[*]
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
